{
  "expo": {
    "name": "Vintract",
    "slug": "vintract-mobile",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "vintract",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#1A1334"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vintract.mobile"
    },
    "android": {
      "package": "com.vintract.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#1A1334",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Vintract to scan SKU barcodes on the shop floor.",
          "recordAudioAndroid": false
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0b847da0-f23d-4989-a9dc-866a773d3475"
      }
    },
    "owner": "nenu_krishna"
  }
}
